# .htaccess — Probably Fine Garage Doors. Hostinger (Apache) reads this on deploy.
# Clean extensionless directory-style URLs + Force HTTPS, gzip, long-cache, protect internal files.

# ---- Clean URLs + Force HTTPS (FLEET-STANDARDS §0) -----------------------------------
Options +FollowSymLinks -Indexes
DirectoryIndex index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP:X-Forwarded-Proto} =http
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  # strip index.html (root or subdir) -> directory
  RewriteCond %{THE_REQUEST} \s/+(([^?\s]*/)?)index\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]
  # /page.html -> /page/   (301; consolidates old links)
  RewriteCond %{THE_REQUEST} \s/+([^?\s]+)\.html[\s?] [NC]
  RewriteRule ^ /%1/ [R=301,L]
  # serve /page/ (or /page) from /page.html
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^([^/]+)/?$ $1.html [L]
  RewriteRule ^(_build|_shared)/ - [F,L]
</IfModule>

# ---- Protect internal / brain files from being served on the public site -------------
# The _shared submodule and any markdown (incl. CREDENTIALS.md) must never be downloadable.
RedirectMatch 404 ^/_shared/
<FilesMatch "\.(md|json|mjs|sh|gitmodules)$">
  Require all denied
</FilesMatch>
# Allow the site's own public JSON if needed (e.g. manifest) by exception:
<Files "site.webmanifest">
  Require all granted
</Files>

# ---- Gzip / compression --------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml application/json
</IfModule>

# ---- Cache static assets long; HTML short --------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp        "access plus 1 year"
  ExpiresByType image/jpeg        "access plus 1 year"
  ExpiresByType image/png         "access plus 1 year"
  ExpiresByType image/svg+xml     "access plus 1 year"
  ExpiresByType text/css          "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html         "access plus 0 seconds"
</IfModule>

# ---- Security/UX headers -------------------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

ErrorDocument 404 /404.html
